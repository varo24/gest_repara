rules_version = '2';

// ─────────────────────────────────────────────────────────────────────────────
// Firestore Security Rules — gestrepara
// Protección: Anonymous Auth. Solo clientes con sesión Firebase válida
// (incluye sesiones anónimas creadas por la propia app) pueden leer/escribir.
// Cualquier acceso externo directo a la API REST o SDK sin token → denegado.
// ─────────────────────────────────────────────────────────────────────────────

service cloud.firestore {
  match /databases/{database}/documents {

    // Logs de error: write-only público (para poder loguear antes de auth)
    match /error_logs/{doc} {
      allow create: if true;
      allow read, update, delete: if false;
    }

    // Todas las demás colecciones: requieren sesión Firebase válida
    match /{collection}/{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
